---
import {
	getMenu,
	getEmDashCollection,
	getSiteSettings,
	getTaxonomyTerms,
} from "emdash";
import {
	WidgetArea,
	EmDashHead,
	EmDashBodyStart,
	EmDashBodyEnd,
} from "emdash/ui";
import { createPublicPageContext } from "emdash/page";
import LiveSearch from "emdash/ui/search";
import "../styles/theme.css";

interface Props {
	title: string;
	description?: string | null;
	image?: string | null;
	canonical?: string | null;
	robots?: string | null;
	type?: "website" | "article";
	publishedTime?: string | null;
	modifiedTime?: string | null;
	author?: string | null;
	content?: { collection: string; id: string; slug?: string | null };
}

const {
	title,
	description,
	image,
	canonical,
	robots,
	type = "website",
	publishedTime,
	modifiedTime,
	author,
	content,
} = Astro.props;

const siteSettings = await getSiteSettings();
const siteTitle = siteSettings.title?.trim() || "The Sonderise Chronicle";
const siteTagline =
	siteSettings.tagline?.trim() ||
	"Independent dispatches on design, systems, and digital culture.";
const fullTitle = title.includes(siteTitle) ? title : `${title} | ${siteTitle}`;

const menu = await getMenu("primary");
const menuItems = menu?.items ?? [];
const categories = await getTaxonomyTerms("category");
const sectionLinks = categories.slice(0, 6);
const { entries: pages } = await getEmDashCollection("pages", { limit: 6 });
const footerPages = pages.slice(0, 4);

const pageCtx = createPublicPageContext({
	Astro,
	kind: content ? "content" : "custom",
	pageType: type,
	title: fullTitle,
	description,
	canonical,
	image,
	content,
	seo: { ogImage: image, robots },
	articleMeta: { publishedTime, modifiedTime, author },
	siteName: siteTitle,
});

const isLoggedIn = !!Astro.locals.user;
const editionDateLong = new Intl.DateTimeFormat("en-US", {
	weekday: "long",
	month: "long",
	day: "numeric",
	year: "numeric",
}).format(new Date());
const editionIso = new Date().toISOString();
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@600;700&family=Libre+Franklin:wght@400;500;600;700&family=Source+Serif+4:opsz,wght@8..60,400;8..60,500;8..60,600;8..60,700&display=swap"
			rel="stylesheet"
		/>
		<title>{fullTitle}</title>
		<EmDashHead page={pageCtx} />
	</head>
	<body>
		<EmDashBodyStart page={pageCtx} />
		<header class="site-header">
			<div class="site-header__utility">
				<div class="site-header__utility-inner">
					<p class="utility-date">
						<time datetime={editionIso}>{editionDateLong}</time>
					</p>

					<div class="utility-actions">
						<a href="/posts">Today&apos;s edition</a>
						<a href="/search">Search</a>
						<a href="/rss.xml">RSS</a>
						{
							isLoggedIn && (
								<a href="/_emdash/admin" class="utility-action utility-action--button">
									Newsroom
								</a>
							)
						}
					</div>
				</div>
			</div>

			<div class="site-header__masthead">
				<div class="site-header__masthead-inner">
					<p class="masthead-note">{siteTagline}</p>

					<div class="masthead-brand">
						<a href="/" class="site-title">{siteTitle}</a>
						<p class="site-title-meta">Independent digital paper</p>
					</div>

					<div class="masthead-search">
						<LiveSearch
							placeholder="Search stories"
							class="site-search"
							inputClass="site-search-input"
							resultsClass="site-search-results"
							resultClass="site-search-result"
							collections={["posts", "pages"]}
							expandOnFocus={{ collapsed: "100%", expanded: "100%" }}
						/>
					</div>
				</div>
			</div>

			<nav class="site-nav" aria-label="Primary">
				<div class="site-nav__inner">
					<ul class="nav-links">
						{menuItems.length > 0 ? (
							menuItems.map((item) => (
								<li
									class:list={[
										"nav-item",
										item.children.length > 0 && "nav-item--has-children",
									]}
								>
									<a
										href={item.url}
										target={item.target}
										rel={
											item.target === "_blank" ? "noopener noreferrer" : undefined
										}
									>
										{item.label}
									</a>
									{
										item.children.length > 0 && (
											<ul class="nav-submenu">
												{item.children.map((child) => (
													<li>
														<a
															href={child.url}
															target={child.target}
															rel={
																child.target === "_blank"
																	? "noopener noreferrer"
																	: undefined
															}
														>
															{child.label}
														</a>
													</li>
												))}
											</ul>
										)
									}
								</li>
							))
						) : (
							<li class="nav-item">
								<a href="/posts">Latest stories</a>
							</li>
						)}

						{sectionLinks.map((category) => (
							<li class="nav-item nav-item--section">
								<a href={`/category/${category.slug}`}>{category.label}</a>
							</li>
						))}

						<li class="nav-item nav-item--mobile-search">
							<a href="/search">Search</a>
						</li>
					</ul>
				</div>
			</nav>
		</header>

		<main>
			<slot />
		</main>

		<footer class="site-footer">
			<div class="footer-inner">
				<div class="footer-nameplate">
					<a href="/" class="footer-logo">{siteTitle}</a>
					<p class="footer-tagline">{siteTagline}</p>
				</div>

				<div class="footer-grid">
					<div class="footer-nav">
						<h2 class="footer-heading">Read</h2>
						<ul class="footer-links">
							<li><a href="/">Front page</a></li>
							<li><a href="/posts">Latest stories</a></li>
							<li><a href="/search">Search</a></li>
							<li><a href="/rss.xml">RSS feed</a></li>
						</ul>
					</div>

					{
						sectionLinks.length > 0 && (
							<div class="footer-nav">
								<h2 class="footer-heading">Sections</h2>
								<ul class="footer-links">
									{sectionLinks.map((category) => (
										<li>
											<a href={`/category/${category.slug}`}>{category.label}</a>
										</li>
									))}
								</ul>
							</div>
						)
					}

					<div class="footer-nav">
						<h2 class="footer-heading">Pages</h2>
						<ul class="footer-links">
							{footerPages.map((page) => (
								<li>
									<a href={`/pages/${page.data.slug || page.id}`}>
										{page.data.title}
									</a>
								</li>
							))}
						</ul>
					</div>

					<div class="footer-widgets-section">
						<h2 class="footer-heading">From the desk</h2>
						<WidgetArea name="footer" />
					</div>
				</div>

				<div class="footer-bottom">
					<p class="footer-copyright">
						Built on <a href="https://emdashcms.com">EmDash</a> for thoughtful
						digital publishing.
					</p>
				</div>
			</div>
		</footer>

		<style is:global>
			*:where(:not([class*="emdash"]):not([class*="ec-"])),
			*:where(:not([class*="emdash"]):not([class*="ec-"]))::before,
			*:where(:not([class*="emdash"]):not([class*="ec-"]))::after {
				box-sizing: border-box;
			}

			html {
				scroll-behavior: smooth;
			}

			body,
			h1,
			h2,
			h3,
			h4,
			h5,
			h6,
			p,
			ul,
			ol,
			figure,
			blockquote,
			dl,
			dd {
				margin: 0;
			}

			ul,
			ol {
				padding: 0;
			}

			:root {
				--color-bg: var(--theme-color-bg, #ffffff);
				--color-bg-subtle: var(--theme-color-bg-subtle, #f7f7f5);
				--color-text: var(--theme-color-text, #121212);
				--color-text-secondary: var(--theme-color-text-secondary, #363636);
				--color-muted: var(--theme-color-muted, #666666);
				--color-border: var(--theme-color-border, #d9d9d9);
				--color-border-subtle: var(--theme-color-border-subtle, #ebebeb);
				--color-surface: var(--theme-color-surface, #ffffff);
				--color-accent: var(--theme-color-accent, #326891);
				--color-accent-hover: var(--theme-color-accent-hover, #1e4f75);
				--color-on-accent: var(--theme-color-on-accent, #ffffff);
				--color-accent-ring: var(
					--theme-color-accent-ring,
					color-mix(in srgb, var(--color-accent) 24%, transparent)
				);

				--emdash-search-bg: var(--color-surface);
				--emdash-search-text: var(--color-text);
				--emdash-search-muted: var(--color-muted);
				--emdash-search-border: var(--color-border);
				--emdash-search-hover: var(--color-bg-subtle);
				--emdash-search-highlight: var(--color-text);

				--font-sans:
					var(
						--theme-font-sans,
						"Libre Franklin",
						"Helvetica Neue",
						Arial,
						sans-serif
					);
				--font-serif:
					var(--theme-font-serif, "Source Serif 4", Georgia, serif);
				--font-display:
					var(--theme-font-display, "Source Serif 4", Georgia, serif);
				--font-masthead:
					var(
						--theme-font-masthead,
						"Cormorant Garamond",
						Georgia,
						serif
					);
				--font-mono:
					var(
						--theme-font-mono,
						"IBM Plex Mono",
						ui-monospace,
						SFMono-Regular,
						Menlo,
						monospace
					);

				--font-size-xs: var(--theme-font-size-xs, 0.72rem);
				--font-size-sm: var(--theme-font-size-sm, 0.92rem);
				--font-size-base: var(--theme-font-size-base, 1.04rem);
				--font-size-lg: var(--theme-font-size-lg, 1.18rem);
				--font-size-xl: var(--theme-font-size-xl, 1.55rem);
				--font-size-2xl: var(--theme-font-size-2xl, 2rem);
				--font-size-3xl: var(--theme-font-size-3xl, 2.8rem);
				--font-size-4xl: var(--theme-font-size-4xl, 3.8rem);
				--font-size-5xl: var(--theme-font-size-5xl, 5.1rem);

				--leading-tight: var(--theme-leading-tight, 0.98);
				--leading-snug: var(--theme-leading-snug, 1.12);
				--leading-normal: var(--theme-leading-normal, 1.55);
				--leading-relaxed: var(--theme-leading-relaxed, 1.72);

				--spacing-1: 0.25rem;
				--spacing-2: 0.5rem;
				--spacing-3: 0.75rem;
				--spacing-4: 1rem;
				--spacing-5: 1.25rem;
				--spacing-6: 1.5rem;
				--spacing-8: 2rem;
				--spacing-10: 2.5rem;
				--spacing-12: 3rem;
				--spacing-16: 4rem;
				--spacing-20: 5rem;
				--spacing-24: 6rem;

				--content-width: var(--theme-content-width, 760px);
				--wide-width: var(--theme-wide-width, 1280px);
				--max-width: var(--content-width);
				--gutter-width: var(--theme-gutter-width, 280px);
				--meta-col-width: var(--theme-meta-col-width, 220px);
				--nav-height: var(--theme-nav-height, 58px);
				--search-input-width: var(--theme-search-input-width, 220px);

				--radius: var(--theme-radius, 0px);
				--radius-lg: var(--theme-radius-lg, 0px);
				--rule-thick: var(--theme-rule-thick, 2px);

				--transition-fast: 140ms ease;
				--transition-base: 220ms ease;

				--tracking-tight: var(--theme-tracking-tight, -0.035em);
				--tracking-snug: var(--theme-tracking-snug, -0.02em);
				--tracking-wide: var(--theme-tracking-wide, 0.08em);
				--tracking-wider: var(--theme-tracking-wider, 0.16em);

				--shadow-dropdown: var(
					--theme-shadow-dropdown,
					0 14px 32px rgba(18, 18, 18, 0.08)
				);
				--shadow-btn-active: var(
					--theme-shadow-btn-active,
					0 2px 6px rgba(18, 18, 18, 0.08)
				);
			}

			body {
				min-height: 100vh;
				background: var(--color-bg);
				color: var(--color-text);
				font-family: var(--font-serif);
				font-size: var(--font-size-base);
				line-height: var(--leading-relaxed);
				-webkit-font-smoothing: antialiased;
				-moz-osx-font-smoothing: grayscale;
				text-wrap: pretty;
			}

			a:where(:not([class*="emdash"]):not([class*="ec-"])) {
				color: var(--color-text);
				text-decoration: none;
				transition:
					color var(--transition-fast),
					opacity var(--transition-fast);
			}

			a:where(:not([class*="emdash"]):not([class*="ec-"])):hover {
				color: var(--color-accent);
			}

			img {
				display: block;
				max-width: 100%;
				height: auto;
			}

			button,
			input,
			textarea,
			select {
				font: inherit;
				font-family: var(--font-sans);
			}

			h1,
			h2,
			h3,
			h4,
			h5,
			h6 {
				font-family: var(--font-display);
				font-weight: 600;
				line-height: var(--leading-tight);
				letter-spacing: var(--tracking-snug);
				text-wrap: balance;
			}

			h1 {
				letter-spacing: var(--tracking-tight);
			}

			::selection {
				background: var(--color-accent);
				color: var(--color-on-accent);
			}
		</style>

		<style>
			.site-header,
			main,
			.site-footer {
				position: relative;
				z-index: 1;
			}

			.site-header {
				background: var(--color-surface);
				border-bottom: 1px solid var(--color-border);
			}

			.site-header__utility,
			.site-header__masthead,
			.site-nav,
			.site-footer {
				background: var(--color-surface);
			}

			.site-header__utility {
				border-bottom: 1px solid var(--color-border-subtle);
			}

			.site-header__utility-inner,
			.site-header__masthead-inner,
			.site-nav__inner,
			.footer-inner {
				max-width: var(--wide-width);
				margin: 0 auto;
				padding-left: var(--spacing-6);
				padding-right: var(--spacing-6);
			}

			.site-header__utility-inner {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: var(--spacing-4);
				min-height: 2.5rem;
			}

			.utility-date,
			.utility-actions,
			.site-title-meta,
			.masthead-note,
			.nav-links a,
			.footer-heading,
			.footer-links,
			.footer-copyright,
			:global(.site-search-input),
			:global(.site-search-result) {
				font-family: var(--font-sans);
			}

			.utility-date,
			.utility-actions a,
			.site-title-meta,
			.masthead-note,
			.nav-links a,
			.footer-heading {
				font-size: var(--font-size-xs);
				font-weight: 600;
				letter-spacing: var(--tracking-wide);
				text-transform: uppercase;
			}

			.utility-date {
				color: var(--color-muted);
			}

			.utility-actions {
				display: flex;
				align-items: center;
				gap: 1rem;
			}

			.utility-actions a {
				color: var(--color-text-secondary);
			}

			.utility-action--button {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				padding: 0.4rem 0.7rem;
				border: 1px solid var(--color-text);
				color: var(--color-text);
			}

			.site-header__masthead {
				border-bottom: 1px solid var(--color-border);
			}

			.site-header__masthead-inner {
				display: grid;
				grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
				align-items: center;
				gap: var(--spacing-6);
				padding-top: 1.15rem;
				padding-bottom: 1rem;
			}

			.masthead-note {
				max-width: 17rem;
				color: var(--color-muted);
				line-height: 1.6;
			}

			.masthead-brand {
				text-align: center;
			}

			.site-title {
				display: inline-block;
				font-family: var(--font-masthead);
				font-size: clamp(3.3rem, 7vw, 5.2rem);
				font-weight: 700;
				line-height: 0.88;
				letter-spacing: -0.04em;
				color: var(--color-text);
			}

			.site-title:hover {
				color: var(--color-text);
			}

			.site-title-meta {
				margin-top: 0.35rem;
				color: var(--color-muted);
			}

			.masthead-search {
				justify-self: end;
				width: min(100%, var(--search-input-width));
			}

			.site-search {
				position: relative;
				width: 100%;
				--emdash-search-border-focus: var(--color-accent);
			}

			:global(.site-search-input) {
				width: 100%;
				min-height: 2.5rem;
				padding: 0.65rem 0.8rem;
				border: 1px solid var(--color-border);
				border-radius: 0;
				background: var(--color-surface);
				color: var(--color-text);
				font-size: var(--font-size-sm);
				transition:
					border-color var(--transition-fast),
					box-shadow var(--transition-fast);
			}

			:global(.site-search-input)::placeholder {
				color: var(--color-muted);
			}

			:global(.site-search-input):focus,
			:global(.site-search-input):focus-visible {
				outline: none;
				border-color: var(--color-accent) !important;
				box-shadow: 0 0 0 3px var(--color-accent-ring);
			}

			:global(.site-search-results) {
				position: absolute;
				top: calc(100% + var(--spacing-2));
				left: 0;
				right: 0;
				max-height: 24rem;
				overflow-y: auto;
				border: 1px solid var(--color-border);
				background: var(--color-surface);
				box-shadow: var(--shadow-dropdown);
				z-index: 30;
			}

			:global(.site-search-results .emdash-live-search-loading),
			:global(.site-search-results .emdash-live-search-no-results) {
				padding: var(--spacing-4);
				text-align: center;
				color: var(--color-muted);
				font-family: var(--font-sans);
				font-size: var(--font-size-sm);
			}

			:global(.site-search-result) {
				display: block;
				padding: 0.9rem 1rem;
				border-bottom: 1px solid var(--color-border-subtle);
				color: var(--color-text);
			}

			:global(.site-search-result:last-child) {
				border-bottom: none;
			}

			:global(.site-search-result:hover),
			:global(.site-search-result:focus),
			:global(.site-search-result.focused) {
				background: var(--color-bg-subtle);
				outline: none;
			}

			:global(.site-search-result .emdash-live-search-result-title) {
				display: block;
				font-size: var(--font-size-sm);
				font-weight: 600;
			}

			:global(.site-search-result .emdash-live-search-result-collection) {
				display: block;
				margin-top: 0.2rem;
				font-size: var(--font-size-xs);
				font-weight: 600;
				letter-spacing: var(--tracking-wide);
				text-transform: uppercase;
				color: var(--color-muted);
			}

			:global(.site-search-result .emdash-live-search-result-snippet) {
				display: block;
				margin-top: 0.35rem;
				font-size: var(--font-size-sm);
				line-height: var(--leading-normal);
				color: var(--color-text-secondary);
			}

			:global(.site-search-result .emdash-live-search-result-snippet mark) {
				background: transparent;
				color: var(--color-accent);
				font-weight: 700;
			}

			.site-nav {
				border-bottom: 1px solid var(--color-border-subtle);
			}

			.site-nav__inner {
				min-height: var(--nav-height);
			}

			.nav-links {
				display: flex;
				align-items: center;
				justify-content: center;
				flex-wrap: wrap;
				gap: 0.9rem 1.25rem;
				list-style: none;
				min-height: var(--nav-height);
			}

			.nav-item {
				position: relative;
			}

			.nav-links a {
				display: inline-flex;
				align-items: center;
				padding: 0.25rem 0;
				color: var(--color-text-secondary);
			}

			.nav-item--section a {
				font-weight: 500;
			}

			.nav-links a:hover,
			.nav-links a:focus-visible {
				color: var(--color-text);
			}

			.nav-submenu {
				position: absolute;
				top: calc(100% + 0.7rem);
				left: 0;
				min-width: 12rem;
				list-style: none;
				border: 1px solid var(--color-border);
				background: var(--color-surface);
				box-shadow: var(--shadow-dropdown);
				opacity: 0;
				visibility: hidden;
				transform: translateY(8px);
				transition:
					opacity var(--transition-fast),
					transform var(--transition-fast),
					visibility var(--transition-fast);
			}

			.nav-item--has-children:hover .nav-submenu,
			.nav-item--has-children:focus-within .nav-submenu {
				opacity: 1;
				visibility: visible;
				transform: translateY(0);
			}

			.nav-submenu li + li {
				border-top: 1px solid var(--color-border-subtle);
			}

			.nav-submenu a {
				width: 100%;
				padding: 0.8rem 0.9rem;
				font-size: var(--font-size-sm);
				font-weight: 500;
				letter-spacing: normal;
				text-transform: none;
			}

			.nav-item--mobile-search {
				display: none;
			}

			main {
				min-height: calc(100vh - 18rem);
			}

			.site-footer {
				margin-top: var(--spacing-20);
				border-top: 2px solid var(--color-text);
			}

			.footer-inner {
				padding-top: var(--spacing-8);
				padding-bottom: var(--spacing-8);
			}

			.footer-nameplate {
				padding-bottom: var(--spacing-6);
				border-bottom: 1px solid var(--color-border);
			}

			.footer-logo {
				display: inline-block;
				font-family: var(--font-masthead);
				font-size: clamp(2.8rem, 6vw, 4rem);
				font-weight: 700;
				line-height: 0.9;
				letter-spacing: -0.04em;
				color: var(--color-text);
			}

			.footer-logo:hover {
				color: var(--color-text);
			}

			.footer-tagline {
				margin-top: 0.45rem;
				max-width: 34rem;
				font-family: var(--font-sans);
				font-size: var(--font-size-sm);
				line-height: 1.7;
				color: var(--color-text-secondary);
			}

			.footer-grid {
				display: grid;
				grid-template-columns: repeat(4, minmax(0, 1fr));
				gap: var(--spacing-8);
				padding-top: var(--spacing-8);
			}

			.footer-heading {
				margin-bottom: var(--spacing-4);
				color: var(--color-muted);
			}

			.footer-links {
				list-style: none;
				font-size: var(--font-size-sm);
			}

			.footer-links li + li {
				margin-top: 0.8rem;
			}

			.footer-links a {
				color: var(--color-text-secondary);
			}

			.footer-links a:hover {
				color: var(--color-text);
			}

			.footer-widgets-section :global(.widget-area) {
				display: block;
			}

			.footer-widgets-section :global(.widget) {
				color: var(--color-text-secondary);
			}

			.footer-widgets-section :global(.widget__title) {
				display: none;
			}

			.footer-widgets-section :global(.widget__content) {
				font-size: var(--font-size-sm);
				line-height: 1.8;
			}

			.footer-bottom {
				margin-top: var(--spacing-8);
				padding-top: var(--spacing-5);
				border-top: 1px solid var(--color-border);
			}

			.footer-copyright {
				font-size: var(--font-size-sm);
				line-height: 1.6;
				color: var(--color-muted);
			}

			.footer-copyright a {
				color: var(--color-text-secondary);
			}

			@media (max-width: 1100px) {
				.site-header__masthead-inner {
					grid-template-columns: minmax(0, 1fr);
					text-align: center;
				}

				.masthead-note {
					order: 2;
					max-width: none;
				}

				.masthead-search {
					order: 3;
					justify-self: center;
					width: min(100%, 28rem);
				}

				.footer-grid {
					grid-template-columns: repeat(2, minmax(0, 1fr));
				}
			}

			@media (max-width: 760px) {
				.site-header__utility-inner,
				.site-header__masthead-inner,
				.site-nav__inner,
				.footer-inner {
					padding-left: var(--spacing-4);
					padding-right: var(--spacing-4);
				}

				.site-header__utility-inner {
					flex-direction: column;
					align-items: flex-start;
					padding-top: 0.55rem;
					padding-bottom: 0.55rem;
				}

				.utility-actions {
					flex-wrap: wrap;
					gap: 0.55rem 0.8rem;
				}

				.site-title {
					font-size: clamp(2.7rem, 12vw, 4rem);
				}

				.masthead-search {
					display: none;
				}

				.nav-links {
					justify-content: flex-start;
					overflow-x: auto;
					flex-wrap: nowrap;
					scrollbar-width: none;
				}

				.nav-links::-webkit-scrollbar {
					display: none;
				}

				.nav-item--mobile-search {
					display: list-item;
				}

				.footer-grid {
					grid-template-columns: 1fr;
					gap: var(--spacing-6);
				}
			}
		</style>

		<script>
			document.addEventListener("keydown", (e) => {
				if ((e.metaKey || e.ctrlKey) && e.key === "k") {
					e.preventDefault();
					const searchInput = document.querySelector(
						".site-search-input"
					) as HTMLInputElement | null;
					if (searchInput) {
						searchInput.focus();
					} else {
						window.location.href = "/search";
					}
				}
			});
		</script>
		<EmDashBodyEnd page={pageCtx} />
	</body>
</html>

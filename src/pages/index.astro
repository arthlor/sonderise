---
import {
	getEmDashCollection,
	getEntryTerms,
	getSection,
	getSiteSettings,
	getTaxonomyTerms,
} from "emdash";
import { Image, PortableText } from "emdash/ui";
import Base from "../layouts/Base.astro";
import PostCard from "../components/PostCard.astro";
import { getReadingTime } from "../utils/reading-time";

const siteSettings = await getSiteSettings();
const siteTitle = siteSettings.title?.trim() || "The Sonderise Chronicle";
const siteTagline =
	siteSettings.tagline?.trim() ||
	"Independent dispatches on design, systems, and digital culture.";

const { entries: posts, cacheHint } = await getEmDashCollection("posts", {
	orderBy: { published_at: "desc" },
});

Astro.cache.set(cacheHint);

const sortedPosts = posts.toSorted((a, b) => {
	const dateA = a.data.publishedAt?.getTime() ?? 0;
	const dateB = b.data.publishedAt?.getTime() ?? 0;
	return dateB - dateA;
});

const stories = await Promise.all(
	sortedPosts.map(async (post) => {
		const [tags, categories] = await Promise.all([
			getEntryTerms("posts", post.data.id, "tag"),
			getEntryTerms("posts", post.data.id, "category"),
		]);

		return {
			post,
			tags: tags.map((tag) => ({ slug: tag.slug, label: tag.label })),
			categories: categories.map((category) => ({
				slug: category.slug,
				label: category.label,
			})),
			bylines: post.data.bylines ?? [],
			readingTime: getReadingTime(post.data.content),
		};
	})
);

const leadStory = stories[0] ?? null;
const supportingStories = stories.slice(1, 4);
const briefingStories = stories.slice(4, 8);
const archiveStories =
	stories.slice(8, 12).length > 0 ? stories.slice(8, 12) : stories.slice(3, 7);

const categoryTerms = await getTaxonomyTerms("category");
const desks = categoryTerms
	.map((term) => ({
		term,
		stories: stories
			.filter((story) =>
				story.categories.some((category) => category.slug === term.slug)
			)
			.slice(0, 3),
	}))
	.filter((desk) => desk.stories.length > 0)
	.slice(0, 3);

const newsletterSection = await getSection("newsletter-signup");

function formatDate(date: Date | null | undefined) {
	if (!date) return null;
	return date.toLocaleDateString("en-US", {
		month: "long",
		day: "numeric",
		year: "numeric",
	});
}
---

<Base title={siteTitle} description={siteTagline}>
	{
		stories.length === 0 ? (
			<section class="empty-state">
				<p class="section-marker">Ready to publish</p>
				<h1>Shape the first edition.</h1>
				<p>
					Open the newsroom, publish your first piece, and turn this starter into
					a living digital journal.
				</p>
				<a href="/_emdash/admin/content/posts/new" class="home-action home-action--primary">
					Start writing
				</a>
			</section>
		) : (
			<div class="home-content">
				<section class="hero-stage">
					<div class="hero-stage__inner">
						<div class="hero-stage__copy">
							<p class="section-marker section-marker--light">
								Independent digital journal
							</p>
							<h1 class="home-title">{siteTitle}</h1>
							<p class="home-intro">{siteTagline}</p>

							<div class="home-actions">
								{
									leadStory && (
										<a
											href={`/posts/${leadStory.post.id}`}
											class="home-action home-action--primary"
										>
											Read the cover story
										</a>
									)
								}
								<a href="/posts" class="home-action home-action--secondary">
									Browse the archive
								</a>
							</div>

							<dl class="home-stats">
								<div>
									<dt>Latest edition</dt>
									<dd>
										{leadStory?.post.data.publishedAt
											? formatDate(leadStory.post.data.publishedAt)
											: "Freshly updated"}
									</dd>
								</div>
								<div>
									<dt>Stories</dt>
									<dd>{stories.length} published reads</dd>
								</div>
								<div>
									<dt>Desks</dt>
									<dd>{desks.length || categoryTerms.length} active beats</dd>
								</div>
							</dl>
						</div>

						{
							leadStory && (
								<article class="hero-story">
									{
										leadStory.post.data.featured_image && (
											<a
												href={`/posts/${leadStory.post.id}`}
												class="hero-story__media"
											>
												<Image image={leadStory.post.data.featured_image} />
											</a>
										)
									}

									<div class="hero-story__body">
										<div class="story-kickers">
											{leadStory.categories.slice(0, 2).map((category) => (
												<a href={`/category/${category.slug}`}>{category.label}</a>
											))}
										</div>

										<div class="story-meta">
											{leadStory.bylines[0] && (
												<span>{leadStory.bylines[0].byline.displayName}</span>
											)}
											{leadStory.bylines[0] &&
												leadStory.post.data.publishedAt && <span>•</span>}
											{leadStory.post.data.publishedAt && (
												<time>{formatDate(leadStory.post.data.publishedAt)}</time>
											)}
											<span>•</span>
											<span>{leadStory.readingTime} min read</span>
										</div>

										<a
											href={`/posts/${leadStory.post.id}`}
											class="hero-story__title-link"
										>
											<h2 class="hero-story__title">{leadStory.post.data.title}</h2>
										</a>

										{leadStory.post.data.excerpt && (
											<p class="hero-story__excerpt">
												{leadStory.post.data.excerpt}
											</p>
										)}

										{
											leadStory.tags.length > 0 && (
												<div class="hero-story__tags">
													{leadStory.tags.slice(0, 3).map((tag) => (
														<a href={`/tag/${tag.slug}`}>{tag.label}</a>
													))}
												</div>
											)
										}
									</div>
								</article>
							)
						}

						{
							supportingStories.length > 0 && (
								<aside class="hero-rail">
									<header class="hero-rail__header">
										<p class="section-marker section-marker--light">Fresh reads</p>
										<a href="/posts">See everything</a>
									</header>

									<div class="hero-rail__list">
										{supportingStories.map((story, index) => (
											<article class="hero-rail__item">
												<span class="hero-rail__index">
													{String(index + 1).padStart(2, "0")}
												</span>
												<div class="hero-rail__body">
													<div class="story-kickers">
														{story.categories.slice(0, 1).map((category) => (
															<a href={`/category/${category.slug}`}>
																{category.label}
															</a>
														))}
													</div>
													<a
														href={`/posts/${story.post.id}`}
														class="hero-rail__title-link"
													>
														<h3 class="hero-rail__title">
															{story.post.data.title}
														</h3>
													</a>
													<div class="story-meta">
														{story.post.data.publishedAt && (
															<time>{formatDate(story.post.data.publishedAt)}</time>
														)}
														<span>•</span>
														<span>{story.readingTime} min read</span>
													</div>
												</div>
											</article>
										))}
									</div>
								</aside>
							)
						}
					</div>
				</section>

				<div class="home-content__body">
					{
						(briefingStories.length > 0 || desks.length > 0) && (
							<section class="edition-layout">
								<div class="edition-layout__intro">
									<p class="section-marker">Inside this issue</p>
									<h2 class="edition-layout__title">
										Read from big-picture thinking into small practical craft.
									</h2>
									<p class="edition-layout__copy">
										Start with the newest signals, then dive by desk to follow the
										conversations shaping this publication.
									</p>
									{
										desks.length > 0 && (
											<div class="desk-pills">
												{desks.map((desk) => (
													<a href={`/category/${desk.term.slug}`} class="desk-pill">
														{desk.term.label}
													</a>
												))}
											</div>
										)
									}
								</div>

								{
									briefingStories.length > 0 && (
										<ol class="briefing-grid">
											{briefingStories.map((story, index) => (
												<li class="briefing-item">
													<span class="briefing-item__index">
														{String(index + 1).padStart(2, "0")}
													</span>
													<div>
														<div class="story-kickers">
															{story.categories.slice(0, 1).map((category) => (
																<a href={`/category/${category.slug}`}>
																	{category.label}
																</a>
															))}
														</div>
														<a
															href={`/posts/${story.post.id}`}
															class="briefing-item__link"
														>
															{story.post.data.title}
														</a>
														{story.post.data.excerpt && (
															<p class="briefing-item__excerpt">
																{story.post.data.excerpt}
															</p>
														)}
														<div class="story-meta">
															{story.post.data.publishedAt && (
																<time>{formatDate(story.post.data.publishedAt)}</time>
															)}
															<span>•</span>
															<span>{story.readingTime} min read</span>
														</div>
													</div>
												</li>
											))}
										</ol>
									)
								}
							</section>
						)
					}

					{
						desks.length > 0 && (
							<section class="news-desks">
								<header class="section-heading">
									<div>
										<p class="section-marker">Read by desk</p>
										<h2>Move through the publication the way an editor would.</h2>
									</div>
									<a href="/search">Search the archive</a>
								</header>

								<div class="news-desks__grid">
									{desks.map((desk) => (
										<section class="news-desk">
											<header class="news-desk__header">
												<p class="section-marker">{desk.term.label}</p>
												<a href={`/category/${desk.term.slug}`}>View section</a>
											</header>

											{
												desk.stories[0] && (
													<article class="desk-feature">
														<a
															href={`/posts/${desk.stories[0].post.id}`}
															class="desk-feature__title-link"
														>
															<h3 class="desk-feature__title">
																{desk.stories[0].post.data.title}
															</h3>
														</a>
														{desk.stories[0].post.data.excerpt && (
															<p class="desk-feature__excerpt">
																{desk.stories[0].post.data.excerpt}
															</p>
														)}
													</article>
												)
											}

											<ul class="desk-list">
												{desk.stories.slice(1).map((story) => (
													<li class="desk-list__item">
														<a href={`/posts/${story.post.id}`}>
															{story.post.data.title}
														</a>
														<div class="story-meta">
															{story.post.data.publishedAt && (
																<time>{formatDate(story.post.data.publishedAt)}</time>
															)}
														</div>
													</li>
												))}
											</ul>
										</section>
									))}
								</div>
							</section>
						)
					}

					{
						newsletterSection && (
							<section class="newsletter-panel">
								<div class="newsletter-panel__inner">
									<div class="newsletter-panel__copy">
										<p class="section-marker section-marker--light">
											Stay in the loop
										</p>
										<h2 class="newsletter-panel__title">
											{newsletterSection.title ?? "Join the next edition"}
										</h2>
										<div class="newsletter-panel__content">
											<PortableText value={newsletterSection.content} />
										</div>
									</div>

									<div class="newsletter-panel__aside">
										<p class="newsletter-panel__eyebrow">
											Slow publishing, sharper ideas.
										</p>
										<p class="newsletter-panel__note">
											Every edition favors perspective over volume, so returning
											readers can catch up quickly and keep going deeper.
										</p>
										<a href="/posts" class="newsletter-panel__link">
											Catch up on recent reporting
										</a>
									</div>
								</div>
							</section>
						)
					}

					{
						archiveStories.length > 0 && (
							<section class="reading-grid">
								<header class="section-heading reading-grid__header">
									<div>
										<p class="section-marker">From the archive</p>
										<h2>More stories worth your time.</h2>
									</div>
									<a href="/posts">View all posts</a>
								</header>

								<div class="reading-grid__cards">
									{archiveStories.map((story) => (
										<PostCard
											title={story.post.data.title ?? "Untitled"}
											excerpt={story.post.data.excerpt}
											featuredImage={story.post.data.featured_image}
											href={`/posts/${story.post.id}`}
											date={story.post.data.publishedAt ?? undefined}
											readingTime={story.readingTime}
											tags={story.tags}
											bylines={story.bylines}
										/>
									))}
								</div>
							</section>
						)
					}
				</div>
			</div>
		)
	}
</Base>

<style>
	.home-content {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding-top: var(--spacing-8);
	}

	.home-content__body {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: clamp(3rem, 5vw, 4.5rem) var(--spacing-6) 0;
	}

	.home-content__body > section + section {
		margin-top: clamp(4rem, 8vw, 6rem);
	}

	.section-marker {
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: var(--tracking-wider);
		color: var(--color-muted);
	}

	.section-marker--light {
		color: rgba(255, 247, 236, 0.72);
	}

	.story-kickers {
		display: flex;
		flex-wrap: wrap;
		gap: var(--spacing-2);
		margin-bottom: var(--spacing-3);
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: var(--tracking-wide);
	}

	.story-kickers a {
		color: color-mix(in srgb, var(--color-accent) 80%, var(--color-text));
	}

	.story-meta {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: var(--spacing-2);
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		text-transform: uppercase;
		letter-spacing: var(--tracking-wide);
		color: var(--color-muted);
	}

	.hero-stage {
		position: relative;
		margin-inline: calc(50% - 50vw);
		background:
			radial-gradient(circle at 16% 18%, rgba(255, 255, 255, 0.14), transparent 22%),
			radial-gradient(circle at 84% 12%, rgba(234, 106, 66, 0.32), transparent 18%),
			linear-gradient(135deg, #0f1522 0%, #172030 40%, #1f2435 70%, #35263b 100%);
		color: #fff7ef;
		overflow: clip;
	}

	.hero-stage::before {
		content: "";
		position: absolute;
		inset: 0;
		background:
			linear-gradient(rgba(255, 255, 255, 0.08) 1px, transparent 1px),
			linear-gradient(90deg, rgba(255, 255, 255, 0.08) 1px, transparent 1px);
		background-size: 84px 84px;
		opacity: 0.18;
		pointer-events: none;
	}

	.hero-stage__inner {
		position: relative;
		z-index: 1;
		display: grid;
		grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.15fr) minmax(280px, 0.58fr);
		align-items: end;
		gap: clamp(1.5rem, 3vw, 2.75rem);
		max-width: min(1440px, 100%);
		margin: 0 auto;
		padding: clamp(3.2rem, 7vw, 5.8rem) var(--spacing-6) clamp(2.8rem, 5vw, 4.5rem);
		min-height: min(44rem, calc(100svh - var(--nav-height) - 2rem));
	}

	.hero-stage__copy,
	.hero-story,
	.hero-rail {
		opacity: 0;
		animation: rise-in 0.85s cubic-bezier(0.22, 1, 0.36, 1) forwards;
	}

	.hero-story {
		animation-delay: 0.08s;
	}

	.hero-rail {
		animation-delay: 0.16s;
	}

	.home-title {
		font-size: clamp(3.8rem, 8vw, 7.5rem);
		line-height: 0.86;
		max-width: 8ch;
		color: #fff7ef;
	}

	.home-intro {
		margin-top: var(--spacing-4);
		max-width: 31rem;
		font-family: var(--font-sans);
		font-size: clamp(1.08rem, 1.5vw, 1.24rem);
		line-height: 1.75;
		color: rgba(255, 247, 236, 0.78);
	}

	.home-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.85rem;
		margin-top: var(--spacing-6);
	}

	.home-action {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.95rem 1.25rem;
		border-radius: 999px;
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: var(--tracking-wide);
		transition:
			transform var(--transition-fast),
			background var(--transition-fast),
			border-color var(--transition-fast);
	}

	.home-action:hover {
		transform: translateY(-1px);
	}

	.home-action--primary {
		background: var(--color-accent);
		color: var(--color-on-accent);
	}

	.home-action--primary:hover {
		background: var(--color-accent-hover);
		color: var(--color-on-accent);
	}

	.home-action--secondary {
		border: 1px solid rgba(255, 247, 236, 0.22);
		background: rgba(255, 255, 255, 0.06);
		color: #fff7ef;
	}

	.home-action--secondary:hover {
		border-color: rgba(255, 247, 236, 0.4);
		color: #fff7ef;
	}

	.home-stats {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: var(--spacing-4);
		margin-top: var(--spacing-8);
		padding-top: var(--spacing-5);
		border-top: 1px solid rgba(255, 247, 236, 0.16);
	}

	.home-stats dt {
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: var(--tracking-wide);
		color: rgba(255, 247, 236, 0.56);
	}

	.home-stats dd {
		margin-top: 0.35rem;
		font-family: var(--font-sans);
		font-size: var(--font-size-base);
		line-height: 1.45;
		color: #fff7ef;
	}

	.hero-story {
		display: grid;
		gap: 1.35rem;
		align-self: stretch;
	}

	.hero-story__media {
		position: relative;
		display: block;
		overflow: hidden;
		aspect-ratio: 16 / 11;
		border-radius: 2rem;
		border: 1px solid rgba(255, 255, 255, 0.14);
		box-shadow: 0 28px 70px rgba(4, 6, 14, 0.34);
		background: rgba(255, 255, 255, 0.08);
	}

	.hero-story__media::after {
		content: "";
		position: absolute;
		inset: 0;
		background: linear-gradient(to top, rgba(7, 9, 16, 0.16), transparent 38%);
	}

	.hero-story__media img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 520ms cubic-bezier(0.22, 1, 0.36, 1);
	}

	.hero-story__media:hover img {
		transform: scale(1.04);
	}

	.hero-story__body {
		padding-top: var(--spacing-5);
		border-top: 1px solid rgba(255, 247, 236, 0.18);
	}

	.hero-story__title {
		font-size: clamp(2.35rem, 4vw, 4.35rem);
		line-height: 0.9;
		margin-top: var(--spacing-3);
		color: #fff7ef;
	}

	.hero-story__title-link:hover .hero-story__title {
		color: rgba(255, 247, 236, 0.92);
	}

	.hero-story__excerpt {
		margin-top: var(--spacing-4);
		max-width: 38rem;
		font-family: var(--font-sans);
		font-size: var(--font-size-base);
		line-height: 1.8;
		color: rgba(255, 247, 236, 0.74);
	}

	.hero-story__tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.65rem;
		margin-top: var(--spacing-5);
	}

	.hero-story__tags a {
		display: inline-flex;
		align-items: center;
		padding: 0.5rem 0.8rem;
		border: 1px solid rgba(255, 247, 236, 0.18);
		border-radius: 999px;
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: var(--tracking-wide);
		color: rgba(255, 247, 236, 0.74);
	}

	.hero-stage .story-kickers a,
	.hero-stage .story-meta,
	.hero-stage .hero-rail__header a {
		color: rgba(255, 247, 236, 0.72);
	}

	.hero-rail {
		align-self: stretch;
		padding: 1.35rem;
		border: 1px solid rgba(255, 247, 236, 0.14);
		border-radius: 1.65rem;
		background: rgba(255, 255, 255, 0.06);
		backdrop-filter: blur(16px);
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.08);
	}

	.hero-rail__header {

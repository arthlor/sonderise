---
import {
	getEmDashCollection,
	getEntryTerms,
	getSection,
	getSiteSettings,
	getTaxonomyTerms,
} from "emdash";
import { Image, PortableText } from "emdash/ui";
import Base from "../layouts/Base.astro";
import PostCard from "../components/PostCard.astro";
import { getReadingTime } from "../utils/reading-time";

const siteSettings = await getSiteSettings();
const siteTitle = siteSettings.title?.trim() || "The Sonderise Chronicle";
const siteTagline =
	siteSettings.tagline?.trim() ||
	"Independent dispatches on design, systems, and digital culture.";

const { entries: posts, cacheHint } = await getEmDashCollection("posts", {
	orderBy: { published_at: "desc" },
});

Astro.cache.set(cacheHint);

const sortedPosts = posts.toSorted((a, b) => {
	const dateA = a.data.publishedAt?.getTime() ?? 0;
	const dateB = b.data.publishedAt?.getTime() ?? 0;
	return dateB - dateA;
});

const stories = await Promise.all(
	sortedPosts.map(async (post) => {
		const [tags, categories] = await Promise.all([
			getEntryTerms("posts", post.data.id, "tag"),
			getEntryTerms("posts", post.data.id, "category"),
		]);

		return {
			post,
			tags: tags.map((tag) => ({ slug: tag.slug, label: tag.label })),
			categories: categories.map((category) => ({
				slug: category.slug,
				label: category.label,
			})),
			bylines: post.data.bylines ?? [],
			readingTime: getReadingTime(post.data.content),
		};
	})
);

const leadStory = stories[0] ?? null;
const leftColumnStories = stories.slice(1, 3);
const railStories = stories.slice(3, 7);
const featureGridStories =
	stories.slice(7, 11).length > 0 ? stories.slice(7, 11) : stories.slice(3, 7);
const archiveStories =
	stories.slice(11, 15).length > 0 ? stories.slice(11, 15) : stories.slice(4, 8);

const categoryTerms = await getTaxonomyTerms("category");
const desks = categoryTerms
	.map((term) => ({
		term,
		stories: stories
			.filter((story) =>
				story.categories.some((category) => category.slug === term.slug)
			)
			.slice(0, 3),
	}))
	.filter((desk) => desk.stories.length > 0)
	.slice(0, 3);

const newsletterSection = await getSection("newsletter-signup");

function formatDate(date: Date | null | undefined) {
	if (!date) return null;
	return date.toLocaleDateString("en-US", {
		month: "long",
		day: "numeric",
		year: "numeric",
	});
}

---

<Base title={siteTitle} description={siteTagline}>
	{
		stories.length === 0 ? (
			<section class="empty-state">
				<p class="section-marker">Ready to publish</p>
				<h1>Build the first front page.</h1>
				<p>
					Open the newsroom, publish a first piece, and the paper will start to
					take shape automatically.
				</p>
				<a href="/_emdash/admin/content/posts/new" class="empty-state__action">
					Start writing
				</a>
			</section>
		) : (
			<div class="home-content">
				<section class="lead-package">
					<div class="lead-package__grid">
						<div class="lead-summary">
							<p class="section-marker">Front page</p>
							<h2 class="lead-summary__title">
								A calmer paper for design, systems, and digital culture.
							</h2>
							<p class="lead-summary__copy">{siteTagline}</p>

							<dl class="lead-summary__facts">
								<div>
									<dt>Latest edition</dt>
									<dd>
										{leadStory?.post.data.publishedAt
											? formatDate(leadStory.post.data.publishedAt)
											: "Freshly updated"}
									</dd>
								</div>
								<div>
									<dt>Stories</dt>
									<dd>{stories.length} published reads</dd>
								</div>
								<div>
									<dt>Sections</dt>
									<dd>{desks.length || categoryTerms.length} active desks</dd>
								</div>
							</dl>

							{leftColumnStories.map((story) => (
								<article class="column-story">
									<div class="story-kickers">
										{story.categories.slice(0, 1).map((category) => (
											<a href={`/category/${category.slug}`}>{category.label}</a>
										))}
									</div>
									<a href={`/posts/${story.post.id}`} class="column-story__link">
										<h3 class="column-story__title">{story.post.data.title}</h3>
									</a>
									{story.post.data.excerpt && (
										<p class="column-story__excerpt">{story.post.data.excerpt}</p>
									)}
									<div class="story-meta">
										{story.post.data.publishedAt && (
											<time>{formatDate(story.post.data.publishedAt)}</time>
										)}
										<span>•</span>
										<span>{story.readingTime} min read</span>
									</div>
								</article>
							))}
						</div>

						{
							leadStory && (
								<article class="lead-story">
									<div class="story-kickers">
										{leadStory.categories.slice(0, 2).map((category) => (
											<a href={`/category/${category.slug}`}>{category.label}</a>
										))}
									</div>

									<h1 class="lead-story__title">{leadStory.post.data.title}</h1>

									{leadStory.post.data.excerpt && (
										<p class="lead-story__excerpt">{leadStory.post.data.excerpt}</p>
									)}

									<div class="story-meta">
										{leadStory.bylines[0] && (
											<span>{leadStory.bylines[0].byline.displayName}</span>
										)}
										{leadStory.bylines[0] && leadStory.post.data.publishedAt && (
											<span>•</span>
										)}
										{leadStory.post.data.publishedAt && (
											<time>{formatDate(leadStory.post.data.publishedAt)}</time>
										)}
										<span>•</span>
										<span>{leadStory.readingTime} min read</span>
									</div>

									{
										leadStory.post.data.featured_image && (
											<a
												href={`/posts/${leadStory.post.id}`}
												class="lead-story__media"
											>
												<Image image={leadStory.post.data.featured_image} />
											</a>
										)
									}

									{
										leadStory.tags.length > 0 && (
											<div class="lead-story__tags">
												{leadStory.tags.slice(0, 3).map((tag) => (
													<a href={`/tag/${tag.slug}`}>{tag.label}</a>
												))}
											</div>
										)
									}
								</article>
							)
						}

						<aside class="lead-rail">
							<header class="lead-rail__header">
								<div>
									<p class="section-marker">Latest dispatches</p>
									<h2 class="lead-rail__title">What just moved across the desk.</h2>
								</div>
								<a href="/posts">See all</a>
							</header>

							<div class="lead-rail__list">
								{railStories.length > 0 ? (
									railStories.map((story, index) => (
										<article class="rail-story">
											<span class="rail-story__index">
												{String(index + 1).padStart(2, "0")}
											</span>
											<div>
												<div class="story-kickers">
													{story.categories.slice(0, 1).map((category) => (
														<a href={`/category/${category.slug}`}>
															{category.label}
														</a>
													))}
												</div>
												<a
													href={`/posts/${story.post.id}`}
													class="rail-story__link"
												>
													<h3 class="rail-story__title">{story.post.data.title}</h3>
												</a>
												<div class="story-meta">
													{story.post.data.publishedAt && (
														<time>{formatDate(story.post.data.publishedAt)}</time>
													)}
													<span>•</span>
													<span>{story.readingTime} min read</span>
												</div>
											</div>
										</article>
									))
								) : (
									<p class="lead-rail__empty">
										More reporting will appear here as the next stories land.
									</p>
								)}
							</div>
						</aside>
					</div>
				</section>

				{
					featureGridStories.length > 0 && (
						<section class="story-band">
							<header class="section-heading">
								<div>
									<p class="section-marker">More from the front</p>
									<h2>Sharp reads, arranged the way a paper should feel.</h2>
								</div>
								<a href="/posts">Browse the archive</a>
							</header>

							<div class="story-band__grid">
								{featureGridStories.map((story) => (
									<article class="band-story">
										<div class="story-kickers">
											{story.categories.slice(0, 1).map((category) => (
												<a href={`/category/${category.slug}`}>{category.label}</a>
											))}
										</div>
										<a href={`/posts/${story.post.id}`} class="band-story__link">
											<h3 class="band-story__title">{story.post.data.title}</h3>
										</a>
										{story.post.data.excerpt && (
											<p class="band-story__excerpt">{story.post.data.excerpt}</p>
										)}
										<div class="story-meta">
											{story.post.data.publishedAt && (
												<time>{formatDate(story.post.data.publishedAt)}</time>
											)}
											<span>•</span>
											<span>{story.readingTime} min read</span>
										</div>
									</article>
								))}
							</div>
						</section>
					)
				}

				{
					desks.length > 0 && (
						<section class="desk-sections">
							<header class="section-heading">
								<div>
									<p class="section-marker">Read by desk</p>
									<h2>Move through the paper the way an editor would.</h2>
								</div>
								<a href="/search">Search the archive</a>
							</header>

							<div class="desk-sections__grid">
								{desks.map((desk) => (
									<section class="desk-column">
										<header class="desk-column__header">
											<p class="section-marker">{desk.term.label}</p>
											<a href={`/category/${desk.term.slug}`}>View section</a>
										</header>

										{
											desk.stories[0] && (
												<article class="desk-column__lead">
													<a
														href={`/posts/${desk.stories[0].post.id}`}
														class="desk-column__lead-link"
													>
														<h3 class="desk-column__lead-title">
															{desk.stories[0].post.data.title}
														</h3>
													</a>
													{desk.stories[0].post.data.excerpt && (
														<p class="desk-column__lead-excerpt">
															{desk.stories[0].post.data.excerpt}
														</p>
													)}
												</article>
											)
										}

										<ul class="desk-column__list">
											{desk.stories.slice(1).map((story) => (
												<li class="desk-column__item">
													<a href={`/posts/${story.post.id}`}>
														{story.post.data.title}
													</a>
													<div class="story-meta">
														{story.post.data.publishedAt && (
															<time>{formatDate(story.post.data.publishedAt)}</time>
														)}
													</div>
												</li>
											))}
										</ul>
									</section>
								))}
							</div>
						</section>
					)
				}

				{
					newsletterSection && (
						<section class="late-edition">
							<div class="late-edition__grid">
								<div>
									<p class="section-marker">Late edition</p>
									<h2 class="late-edition__title">A quieter way to stay current.</h2>
								</div>

								<div class="late-edition__content">
									<PortableText value={newsletterSection.content} />
									<a href="/posts" class="late-edition__link">
										Catch up on recent reporting
									</a>
								</div>
							</div>
						</section>
					)
				}

				{
					archiveStories.length > 0 && (
						<section class="reading-grid">
							<header class="section-heading">
								<div>
									<p class="section-marker">From the archive</p>
									<h2>More stories worth staying with.</h2>
								</div>
								<a href="/posts">View all posts</a>
							</header>

							<div class="reading-grid__cards">
								{archiveStories.map((story) => (
									<PostCard
										title={story.post.data.title ?? "Untitled"}
										excerpt={story.post.data.excerpt}
										featuredImage={story.post.data.featured_image}
										href={`/posts/${story.post.id}`}
										date={story.post.data.publishedAt ?? undefined}
										readingTime={story.readingTime}
										tags={story.tags}
										bylines={story.bylines}
									/>
								))}
							</div>
						</section>
					)
				}
			</div>
		)
	}
</Base>

<style>
	.home-content {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-6) var(--spacing-6) 0;
	}

	.home-content > section + section {
		margin-top: clamp(2.8rem, 5vw, 4rem);
	}

	.section-marker,
	.story-kickers,
	.story-meta,
	.lead-summary__facts dt,
	.late-edition__link {
		font-family: var(--font-sans);
	}

	.section-marker,
	.story-kickers,
	.story-meta,
	.lead-summary__facts dt {
		font-size: var(--font-size-xs);
		font-weight: 600;
		letter-spacing: var(--tracking-wide);
		text-transform: uppercase;
		color: var(--color-muted);
	}

	.story-kickers,
	.story-meta {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.3rem 0.55rem;
	}

	.story-kickers a {
		color: var(--color-accent);
	}

	.story-meta {
		color: var(--color-muted);
	}

	.section-heading {
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: var(--spacing-4);
		padding-bottom: var(--spacing-5);
		border-bottom: 1px solid var(--color-border);
	}

	.section-heading h2,
	.lead-rail__title {
		margin-top: 0.5rem;
		font-size: clamp(2rem, 3vw, 2.9rem);
		line-height: 0.95;
		color: var(--color-text);
	}

	.section-heading a,
	.lead-rail__header a,
	.desk-column__header a {
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		font-weight: 600;
		letter-spacing: var(--tracking-wide);
		text-transform: uppercase;
		color: var(--color-text-secondary);
	}

	.lead-package {
		border-top: 2px solid var(--color-text);
		border-bottom: 1px solid var(--color-border);
	}

	.lead-package__grid {
		display: grid;
		grid-template-columns: minmax(250px, 0.72fr) minmax(0, 1.3fr) minmax(250px, 0.78fr);
	}

	.lead-package__grid > * {
		padding: var(--spacing-6);
	}

	.lead-package__grid > * + * {
		border-left: 1px solid var(--color-border);
	}

	.lead-summary__title {
		margin-top: 0.7rem;
		font-size: clamp(2rem, 3vw, 2.8rem);
		line-height: 0.94;
	}

	.lead-summary__copy {
		margin-top: 1rem;
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		line-height: 1.8;
		color: var(--color-text-secondary);
	}

	.lead-summary__facts {
		display: grid;
		gap: 1rem;
		margin-top: var(--spacing-6);
		padding-top: var(--spacing-4);
		border-top: 1px solid var(--color-border);
	}

	.lead-summary__facts dd {
		margin-top: 0.15rem;
		font-size: var(--font-size-sm);
		line-height: 1.6;
		color: var(--color-text);
	}

	.column-story {
		margin-top: var(--spacing-5);
		padding-top: var(--spacing-5);
		border-top: 1px solid var(--color-border-subtle);
	}

	.column-story__title {
		margin-top: 0.45rem;
		font-size: clamp(1.55rem, 2.2vw, 2rem);
		line-height: 1;
		color: var(--color-text);
	}

	.column-story__link:hover .column-story__title {
		color: var(--color-accent);
	}

	.column-story__excerpt {
		margin-top: 0.75rem;
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		line-height: 1.75;
		color: var(--color-text-secondary);
	}

	.column-story .story-meta {
		margin-top: 0.85rem;
	}

	.lead-story__title {
		margin-top: 0.75rem;
		font-size: clamp(3rem, 5vw, 5.2rem);
		line-height: 0.92;
	}

	.lead-story__excerpt {
		margin-top: 1rem;
		max-width: 42rem;
		font-family: var(--font-sans);
		font-size: var(--font-size-base);
		line-height: 1.8;
		color: var(--color-text-secondary);
	}

	.lead-story .story-meta {
		margin-top: 1rem;
	}

	.lead-story__media {
		display: block;
		margin-top: var(--spacing-6);
		border: 1px solid var(--color-border);
		background: var(--color-bg-subtle);
		overflow: hidden;
	}

	.lead-story__media img {
		width: 100%;
		aspect-ratio: 16 / 10;
		object-fit: cover;
		transition: transform 220ms ease;
	}

	.lead-story__media:hover img {
		transform: scale(1.015);
	}

	.lead-story__tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.55rem 0.8rem;
		margin-top: var(--spacing-5);
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		font-weight: 600;
		letter-spacing: var(--tracking-wide);
		text-transform: uppercase;
	}

	.lead-story__tags a {
		color: var(--color-muted);
	}

	.lead-story__tags a:hover {
		color: var(--color-accent);
	}

	.lead-rail__header {
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: var(--spacing-3);
		padding-bottom: var(--spacing-4);
		border-bottom: 1px solid var(--color-border);
	}

	.lead-rail__header a {
		white-space: nowrap;
	}

	.lead-rail__list {
		display: grid;
	}

	.rail-story {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: 0.9rem;
		padding-top: var(--spacing-4);
		margin-top: var(--spacing-4);
		border-top: 1px solid var(--color-border-subtle);
	}

	.rail-story__index {
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		font-weight: 700;
		letter-spacing: var(--tracking-wide);
		text-transform: uppercase;
		color: var(--color-muted);
	}

	.rail-story__title {
		margin-top: 0.4rem;
		font-size: clamp(1.28rem, 1.8vw, 1.6rem);
		line-height: 1.05;
		color: var(--color-text);
	}

	.rail-story__link:hover .rail-story__title {
		color: var(--color-accent);
	}

	.rail-story .story-meta {
		margin-top: 0.75rem;
	}

	.lead-rail__empty {
		padding-top: var(--spacing-4);
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		line-height: 1.75;
		color: var(--color-text-secondary);
	}

	.story-band__grid,
	.desk-sections__grid,
	.reading-grid__cards {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: var(--spacing-6);
		padding-top: var(--spacing-6);
	}

	.band-story {
		padding-top: var(--spacing-4);
		border-top: 1px solid var(--color-border);
	}

	.band-story__title {
		margin-top: 0.4rem;
		font-size: clamp(1.5rem, 2vw, 1.95rem);
		line-height: 1;
		color: var(--color-text);
	}

	.band-story__link:hover .band-story__title {
		color: var(--color-accent);
	}

	.band-story__excerpt {
		margin-top: 0.75rem;
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		line-height: 1.75;
		color: var(--color-text-secondary);
	}

	.band-story .story-meta {
		margin-top: 0.85rem;
	}

	.desk-sections {
		padding-top: var(--spacing-2);
		border-top: 2px solid var(--color-text);
	}

	.desk-sections__grid {
		grid-template-columns: repeat(3, minmax(0, 1fr));
	}

	.desk-column {
		padding-top: var(--spacing-4);
		border-top: 1px solid var(--color-border);
	}

	.desk-column__header {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: var(--spacing-3);
	}

	.desk-column__lead {
		margin-top: var(--spacing-4);
	}

	.desk-column__lead-title {
		font-size: clamp(1.8rem, 2.6vw, 2.35rem);
		line-height: 0.98;
		color: var(--color-text);
	}

	.desk-column__lead-link:hover .desk-column__lead-title {
		color: var(--color-accent);
	}

	.desk-column__lead-excerpt {
		margin-top: 0.85rem;
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		line-height: 1.75;
		color: var(--color-text-secondary);
	}

	.desk-column__list {
		list-style: none;
		margin-top: var(--spacing-5);
	}

	.desk-column__item {
		padding-top: var(--spacing-4);
		margin-top: var(--spacing-4);
		border-top: 1px solid var(--color-border-subtle);
	}

	.desk-column__item a {
		font-size: clamp(1.25rem, 1.7vw, 1.45rem);
		line-height: 1.12;

---
import { getEmDashCollection, getEntryTerms } from "emdash";
import Base from "../../layouts/Base.astro";
import { getReadingTime } from "../../utils/reading-time";

const { entries: posts, cacheHint } = await getEmDashCollection("posts", {
	orderBy: { published_at: "desc" },
});

Astro.cache.set(cacheHint);

const sortedPosts = posts.toSorted((a, b) => {
	const dateA = a.data.publishedAt?.getTime() ?? 0;
	const dateB = b.data.publishedAt?.getTime() ?? 0;
	return dateB - dateA;
});

const postsWithTags = await Promise.all(
	sortedPosts.map(async (post) => {
		const tags = await getEntryTerms("posts", post.data.id, "tag");
		return {
			post,
			tags: tags.map((tag) => ({ slug: tag.slug, label: tag.label })),
			bylines: post.data.bylines ?? [],
			readingTime: getReadingTime(post.data.content),
		};
	})
);

function formatDate(date: Date | null | undefined) {
	if (!date) return null;
	return date.toLocaleDateString("en-US", {
		month: "long",
		day: "numeric",
		year: "numeric",
	});
}
---

<Base title="Story Archive" description="Browse the full story archive">
	<section class="posts-page">
		<header class="page-header">
			<p class="section-marker">Archive</p>
			<h1 class="page-title">All stories</h1>
			<p class="page-description">
				{sortedPosts.length} published piece{sortedPosts.length === 1 ? "" : "s"}
				&nbsp;from the newsroom.
			</p>
		</header>

		{
			sortedPosts.length === 0 ? (
				<p class="empty">Nothing has been published yet.</p>
			) : (
				<div class="posts-list">
					{postsWithTags.map((story) => (
						<article class="post-item">
							<div class="post-item__meta">
								<div class="story-meta">
									{
										story.bylines[0] && (
											<span>{story.bylines[0].byline.displayName}</span>
										)
									}
									{story.bylines[0] && story.post.data.publishedAt && <span>•</span>}
									{story.post.data.publishedAt && (
										<time>{formatDate(story.post.data.publishedAt)}</time>
									)}
									<span>•</span>
									<span>{story.readingTime} min read</span>
								</div>
							</div>

							<div class="post-item__content">
								<a href={`/posts/${story.post.id}`} class="post-link">
									<h2 class="post-title">{story.post.data.title}</h2>
								</a>

								{story.post.data.excerpt && (
									<p class="post-excerpt">{story.post.data.excerpt}</p>
								)}

								{
									story.tags.length > 0 && (
										<div class="post-tags">
											{story.tags.slice(0, 3).map((tag) => (
												<a href={`/tag/${tag.slug}`} class="post-tag">
													{tag.label}
												</a>
											))}
										</div>
									)
								}
							</div>
						</article>
					))}
				</div>
			)
		}
	</section>
</Base>

<style>
	.posts-page {
		max-width: 72rem;
		margin: 0 auto;
		padding: var(--spacing-10) var(--spacing-6) var(--spacing-16);
	}

	.section-marker,
	.story-meta,
	.post-tag {
		font-family: var(--font-sans);
	}

	.section-marker,
	.story-meta {
		font-size: var(--font-size-xs);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: var(--tracking-wider);
		color: var(--color-muted);
	}

	.page-header {
		position: relative;
		padding-top: var(--spacing-6);
		margin-bottom: var(--spacing-8);
	}

	.page-header::before {
		content: "";
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: var(--rule-thick);
		background: var(--color-border);
	}

	.page-title {
		font-size: clamp(3rem, 7vw, 5rem);
		line-height: 0.92;
		margin: var(--spacing-3) 0 var(--spacing-2);
	}

	.page-description,
	.empty {
		font-size: var(--font-size-lg);
		color: var(--color-text-secondary);
	}

	.posts-list {
		display: grid;
		gap: var(--spacing-6);
	}

	.post-item {
		display: grid;
		grid-template-columns: minmax(190px, 220px) minmax(0, 1fr);
		gap: var(--spacing-6);
		padding-top: var(--spacing-6);
		border-top: 1px solid var(--color-border);
	}

	.post-title {
		font-size: clamp(2rem, 4vw, 3rem);
		line-height: 0.96;
		margin-bottom: var(--spacing-3);
		color: var(--color-text);
	}

	.post-link:hover .post-title {
		color: var(--color-accent);
	}

	.post-excerpt {
		max-width: 40rem;
		color: var(--color-text-secondary);
	}

	.post-tags {
		display: flex;
		flex-wrap: wrap;
		gap: var(--spacing-2);
		margin-top: var(--spacing-4);
	}

	.post-tag {
		display: inline-flex;
		padding: 0.35rem 0.6rem;
		border: 1px solid var(--color-border);
		font-size: var(--font-size-xs);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: var(--tracking-wide);
		color: var(--color-text-secondary);
	}

	.post-tag:hover {
		border-color: var(--color-accent);
		color: var(--color-text);
	}

	@media (max-width: 720px) {
		.posts-page {
			padding-left: var(--spacing-4);
			padding-right: var(--spacing-4);
		}

		.post-item {
			grid-template-columns: 1fr;
			gap: var(--spacing-3);
		}
	}
</style>

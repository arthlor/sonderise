---
import {
	getEmDashEntry,
	getEmDashCollection,
	getEntryTerms,
	getSeoMeta,
	getSection,
	getSiteSettings,
} from "emdash";
import {
	Image,
	PortableText,
	Comments,
	CommentForm,
	WidgetArea,
} from "emdash/ui";
import Base from "../../layouts/Base.astro";
import PostCard from "../../components/PostCard.astro";
import { getReadingTime } from "../../utils/reading-time";

const { slug } = Astro.params;

if (!slug) {
	return Astro.redirect("/404");
}

const siteSettings = await getSiteSettings();
const siteTitle = siteSettings.title?.trim() || "The Sonderise Chronicle";

const { entry: post, cacheHint } = await getEmDashEntry("posts", slug);

if (!post) {
	return Astro.redirect("/404");
}

Astro.cache.set(cacheHint);

function getImageUrl(img: unknown): string | undefined {
	if (!img || typeof img !== "object") return undefined;
	const image = img as Record<string, unknown>;
	if (typeof image.src === "string" && image.src) {
		return image.src.startsWith("http")
			? image.src
			: `${Astro.url.origin}${image.src}`;
	}

	const meta = image.meta as Record<string, unknown> | undefined;
	const storageKey =
		(typeof meta?.storageKey === "string" ? meta.storageKey : undefined) ||
		(typeof image.id === "string" ? image.id : undefined);

	if (storageKey) {
		return `${Astro.url.origin}/_emdash/api/media/file/${storageKey}`;
	}

	return undefined;
}

const featuredImageUrl = getImageUrl(post.data.featured_image);
const seo = getSeoMeta(post, {
	siteTitle,
	siteUrl: Astro.url.origin,
	path: `/posts/${slug}`,
	defaultOgImage: featuredImageUrl,
});

const [tags, categories, aboutAuthorSection] = await Promise.all([
	getEntryTerms("posts", post.data.id, "tag"),
	getEntryTerms("posts", post.data.id, "category"),
	getSection("about-author"),
]);

const bylines = post.data.bylines ?? [];
const readingTime = getReadingTime(post.data.content);

const { entries: recentPosts } = await getEmDashCollection("posts", {
	orderBy: { published_at: "desc" },
	limit: 4,
});

const otherPosts = recentPosts.filter((entry) => entry.id !== post.id).slice(0, 3);
const otherPostsWithTags = await Promise.all(
	otherPosts.map(async (entry) => {
		const postTags = await getEntryTerms("posts", entry.data.id, "tag");
		return {
			post: entry,
			tags: postTags.map((tag) => ({ slug: tag.slug, label: tag.label })),
			bylines: entry.data.bylines ?? [],
			readingTime: getReadingTime(entry.data.content),
		};
	})
);

function formatDate(date: Date | null | undefined) {
	if (!date) return null;
	return date.toLocaleDateString("en-US", {
		month: "long",
		day: "numeric",
		year: "numeric",
	});
}

const publishDate = formatDate(post.data.publishedAt);
---

<Base
	title={seo.title}
	description={seo.description}
	image={seo.ogImage}
	canonical={seo.canonical}
	robots={seo.robots}
	type="article"
	publishedTime={post.data.publishedAt?.toISOString() ?? null}
	modifiedTime={post.data.updatedAt.toISOString()}
	content={{ collection: "posts", id: post.data.id, slug }}
>
	<article class="article">
		{
			post.data.featured_image && (
				<div class="article-hero" {...post.edit.featured_image}>
					<Image image={post.data.featured_image} />
				</div>
			)
		}

		<div class="article-grid">
			<aside class="article-meta-col">
				<div class="meta-sticky">
					{
						bylines.length > 0 && (
							<div class="meta-block byline-block">
								<span class="meta-label">
									{bylines.length === 1 ? "Byline" : "Contributors"}
								</span>
								<div class="bylines">
									{bylines.map((credit) => (
										<div class="byline">
											{credit.byline.avatarMediaId && (
												<img
													src={`/_emdash/api/media/file/${credit.byline.avatarMediaId}`}
													alt={credit.byline.displayName}
													class="byline-avatar"
												/>
											)}
											<div class="byline-info">
												<span class="byline-name">
													{credit.byline.displayName}
												</span>
												{credit.roleLabel && (
													<span class="byline-role">{credit.roleLabel}</span>
												)}
											</div>
										</div>
									))}
								</div>
							</div>
						)
					}

					{
						publishDate && (
							<div class="meta-block">
								<span class="meta-label">Published</span>
								<time class="meta-value">{publishDate}</time>
							</div>
						)
					}

					<div class="meta-block">
						<span class="meta-label">Reading Time</span>
						<span class="meta-value">{readingTime} min read</span>
					</div>

					{
						categories.length > 0 && (
							<div class="meta-block">
								<span class="meta-label">Filed Under</span>
								<div class="meta-tags">
									{categories.map((category) => (
										<a href={`/category/${category.slug}`} class="meta-tag">
											{category.label}
										</a>
									))}
								</div>
							</div>
						)
					}

					{
						tags.length > 0 && (
							<div class="meta-block">
								<span class="meta-label">Tags</span>
								<div class="meta-tags">
									{tags.map((tag) => (
										<a href={`/tag/${tag.slug}`} class="meta-tag">
											{tag.label}
										</a>
									))}
								</div>
							</div>
						)
					}
				</div>
			</aside>

			<div class="article-main">
				<header class="article-header">
					<div class="story-kickers">
						{categories.map((category) => (
							<a href={`/category/${category.slug}`}>{category.label}</a>
						))}
					</div>

					<div class="article-meta article-meta--mobile">
						{
							bylines.length > 0 && (
								<>
									<span class="article-meta-byline">
										{bylines.map((credit, index) => (
											<>
												{index > 0 && ", "}
												{credit.byline.displayName}
											</>
										))}
									</span>
									<span class="meta-separator">•</span>
								</>
							)
						}
						{publishDate && <time>{publishDate}</time>}
						<span class="meta-separator">•</span>
						<span>{readingTime} min read</span>
					</div>

					<h1 class="article-title" {...post.edit.title}>{post.data.title}</h1>

					{
						post.data.excerpt && (
							<p class="article-excerpt">{post.data.excerpt}</p>
						)
					}
				</header>

				<div class="article-content">
					<PortableText value={post.data.content} />
				</div>

				{
					aboutAuthorSection && (
						<section class="article-card article-card--author">
							<div>
								<p class="section-marker">Author’s Note</p>
								{aboutAuthorSection.title && (
									<h2 class="article-card__title">{aboutAuthorSection.title}</h2>
								)}
							</div>
							<div class="article-card__content">
								<PortableText value={aboutAuthorSection.content} />
							</div>
						</section>
					)
				}

				<div class="article-comments">
					<Comments collection="posts" contentId={post.data.id} threaded />
					<CommentForm collection="posts" contentId={post.data.id} />
				</div>
			</div>

			<aside class="article-sidebar">
				<div class="sidebar-sticky">
					<nav class="toc" aria-label="Table of contents">
						<h4 class="toc-title">On This Page</h4>
						<div class="toc-content" id="toc-content"></div>
					</nav>

					<div class="sidebar-widgets">
						<WidgetArea name="sidebar" />
					</div>
				</div>
			</aside>
		</div>
	</article>

	{
		otherPostsWithTags.length > 0 && (
			<section class="more-posts">
				<div class="more-inner">
					<header class="more-header">
						<p class="section-marker">Continue Reading</p>
						<h2 class="more-title">More from the edition</h2>
					</header>

					<div class="more-grid">
						{otherPostsWithTags.map((story) => (
							<PostCard
								title={story.post.data.title}
								excerpt={story.post.data.excerpt}
								featuredImage={story.post.data.featured_image}
								href={`/posts/${story.post.id}`}
								date={story.post.data.publishedAt ?? undefined}
								readingTime={story.readingTime}
								tags={story.tags}
								bylines={story.bylines}
							/>
						))}
					</div>
				</div>
			</section>
		)
	}

	<script>
		function buildToc() {
			const content = document.querySelector(".article-content");
			const tocContainer = document.getElementById("toc-content");
			if (!content || !tocContainer) return;

			const headings = content.querySelectorAll("h2, h3");
			if (headings.length === 0) {
				const toc = document.querySelector(".toc");
				if (toc instanceof HTMLElement) toc.style.display = "none";
				return;
			}

			const list = document.createElement("ul");
			list.className = "toc-list";

			headings.forEach((heading, index) => {
				if (!heading.id) {
					heading.id = `heading-${index}`;
				}

				const item = document.createElement("li");
				item.className =
					heading.tagName === "H3" ? "toc-item toc-item--nested" : "toc-item";

				const link = document.createElement("a");
				link.href = `#${heading.id}`;
				link.className = "toc-link";
				link.textContent = heading.textContent;

				item.appendChild(link);
				list.appendChild(item);
			});

			tocContainer.appendChild(list);

			const observer = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						const id = entry.target.id;
						const link = tocContainer.querySelector(`a[href="#${id}"]`);
						if (!(link instanceof HTMLElement)) return;

						if (entry.isIntersecting) {
							tocContainer
								.querySelectorAll(".toc-link")
								.forEach((item) => item.classList.remove("active"));
							link.classList.add("active");
						}
					});
				},
				{ rootMargin: "-80px 0px -80% 0px" }
			);

			headings.forEach((heading) => observer.observe(heading));
		}

		buildToc();
	</script>
</Base>

<style>
	.article {
		max-width: var(--wide-width);
		margin: 0 auto;
	}

	.section-marker,
	.story-kickers,
	.article-meta,
	.meta-label,
	.toc-title,
	.sidebar-widgets :global(.widget__title) {
		font-family: var(--font-sans);
	}

	.section-marker,
	.meta-label,
	.toc-title,
	.sidebar-widgets :global(.widget__title) {
		font-size: var(--font-size-xs);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: var(--tracking-wider);
		color: var(--color-muted);
	}

	.story-kickers {
		display: flex;
		flex-wrap: wrap;
		gap: var(--spacing-2);
		margin-bottom: var(--spacing-4);
		font-size: var(--font-size-xs);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: var(--tracking-wide);
	}

	.story-kickers a {
		color: var(--color-accent);
	}

	.article-hero {
		margin: var(--spacing-10) var(--spacing-6) 0;
		border: 1px solid var(--color-border);
		background: var(--color-surface);
		overflow: hidden;
	}

	.article-hero img {
		width: 100%;
		max-height: 620px;
		object-fit: cover;
	}

	.article-grid {
		display: grid;
		grid-template-columns:
			var(--meta-col-width)
			minmax(0, var(--content-width))
			var(--gutter-width);
		gap: var(--spacing-10);
		justify-content: center;
		padding: var(--spacing-10) var(--spacing-6) 0;
	}

	.meta-sticky,
	.sidebar-sticky {
		position: sticky;
		top: calc(var(--nav-height) + var(--spacing-8));
	}

	.meta-block {
		padding-bottom: var(--spacing-5);
		margin-bottom: var(--spacing-5);
		border-bottom: 1px solid var(--color-border-subtle);
	}

	.meta-value {
		display: block;
		margin-top: var(--spacing-2);
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		color: var(--color-text-secondary);
	}

	.meta-tags {
		display: flex;
		flex-wrap: wrap;
		gap: var(--spacing-2);
		margin-top: var(--spacing-3);
	}

	.meta-tag {
		padding: 0.35rem 0.6rem;
		border: 1px solid var(--color-border);
		background: var(--color-surface);
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		text-transform: uppercase;
		letter-spacing: var(--tracking-wide);
		color: var(--color-text-secondary);
	}

	.meta-tag:hover {
		color: var(--color-text);
		border-color: var(--color-accent);
	}

	.bylines {
		display: grid;
		gap: var(--spacing-3);
		margin-top: var(--spacing-3);
	}

	.byline {
		display: flex;
		align-items: center;
		gap: var(--spacing-2);
	}

	.byline-avatar {
		width: var(--avatar-size-lg);
		height: var(--avatar-size-lg);
		border-radius: 50%;
		object-fit: cover;
	}

	.byline-info {
		display: flex;
		flex-direction: column;
	}

	.byline-name {
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		font-weight: 700;
		color: var(--color-text);
	}

	.byline-role {
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		color: var(--color-muted);
		text-transform: uppercase;
		letter-spacing: var(--tracking-wide);
	}

	.article-main {
		min-width: 0;
	}

	.article-header {
		position: relative;
		padding-top: var(--spacing-6);
		margin-bottom: var(--spacing-10);
	}

	.article-header::before {
		content: "";
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: var(--rule-thick);
		background: var(--color-border);
	}

	.article-meta {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: var(--spacing-2);
		font-size: var(--font-size-xs);
		text-transform: uppercase;
		letter-spacing: var(--tracking-wide);
		color: var(--color-muted);
		margin-bottom: var(--spacing-4);
	}

	.article-meta--mobile {
		display: none;
	}

	.article-meta-byline {
		font-weight: 700;
		color: var(--color-text-secondary);
	}

	.meta-separator {
		opacity: 0.5;
	}

	.article-title {
		font-size: clamp(3.2rem, 7vw, 6rem);
		line-height: 0.92;
		margin-bottom: var(--spacing-4);
		color: var(--color-text);
	}

	.article-excerpt {
		max-width: 42rem;
		font-size: var(--font-size-xl);
		line-height: 1.45;
		color: var(--color-text-secondary);
	}

	.article-content {
		font-size: 1.16rem;
		line-height: 1.84;
	}

	.article-content :global(p) {
		margin-bottom: 1.55em;
	}

	.article-content :global(p:first-of-type:first-letter) {
		float: left;
		margin-right: 0.12em;
		font-family: var(--font-display);
		font-size: 4.8em;
		line-height: 0.82;
		color: var(--color-accent);
	}

	.article-content :global(h2) {
		font-size: clamp(2.1rem, 4vw, 3rem);
		margin-top: 2.35em;
		margin-bottom: 0.55em;
		scroll-margin-top: calc(var(--nav-height) + var(--spacing-4));
	}

	.article-content :global(h3) {
		font-size: clamp(1.6rem, 3vw, 2rem);
		margin-top: 1.8em;
		margin-bottom: 0.5em;
		scroll-margin-top: calc(var(--nav-height) + var(--spacing-4));
	}

	.article-content :global(blockquote) {
		margin: 2.4em 0;
		padding: var(--spacing-5) var(--spacing-6);
		border-left: 3px solid var(--color-accent);
		background: color-mix(in srgb, var(--color-accent) 6%, var(--color-surface));
		color: var(--color-text-secondary);
		font-size: var(--font-size-lg);
		font-style: italic;
	}

	.article-content :global(pre) {
		margin: 2em 0;
		padding: var(--spacing-5);
		border: 1px solid var(--color-border);
		background: var(--color-surface);
		overflow-x: auto;
		font-family: var(--font-mono);
		font-size: var(--font-size-sm);
		line-height: 1.65;
	}

	.article-content :global(code) {
		padding: 0.15em 0.35em;
		background: color-mix(in srgb, var(--color-surface) 90%, transparent);
		font-family: var(--font-mono);
		font-size: 0.9em;
	}

	.article-content :global(pre code) {
		padding: 0;
		background: none;
	}

	.article-content :global(ul),
	.article-content :global(ol) {
		margin-bottom: 1.5em;
		padding-left: 1.5em;
	}

	.article-content :global(li) {
		margin-bottom: 0.55em;
	}

	.article-content :global(img) {
		margin: 2.2em 0;
		border: 1px solid var(--color-border);
	}

	.article-content :global(hr) {
		margin: 3em 0;
		border: 0;
		border-top: 1px solid var(--color-border);
	}

	.article-content :global(a) {
		color: var(--color-accent);
		text-decoration: underline;
		text-decoration-thickness: 1px;
		text-underline-offset: 0.18em;
	}

	.article-card {
		display: grid;
		grid-template-columns: minmax(0, 0.4fr) minmax(0, 1fr);
		gap: var(--spacing-6);
		margin-top: var(--spacing-10);
		padding: var(--spacing-6);
		border: 1px solid var(--color-border);
		background: var(--color-surface);
	}

	.article-card__title {
		font-size: clamp(1.8rem, 3vw, 2.5rem);
		line-height: 0.98;
		margin-top: var(--spacing-3);
	}

	.article-card__content {
		font-size: var(--font-size-base);
		color: var(--color-text-secondary);
	}

	.toc {
		padding-bottom: var(--spacing-6);
		margin-bottom: var(--spacing-8);
		border-bottom: 1px solid var(--color-border-subtle);
	}

	.toc-title {
		margin-bottom: var(--spacing-3);
	}

	.toc-content :global(.toc-list) {
		list-style: none;
	}

	.toc-content :global(.toc-item) + :global(.toc-item) {
		margin-top: var(--spacing-2);
	}

	.toc-content :global(.toc-item--nested) {
		padding-left: var(--spacing-3);
	}

	.toc-content :global(.toc-link) {
		display: block;
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		line-height: 1.45;
		color: var(--color-muted);
	}

	.toc-content :global(.toc-link:hover),
	.toc-content :global(.toc-link.active) {
		color: var(--color-text);
	}

	.sidebar-widgets :global(.widget-area) {
		display: grid;
		gap: var(--spacing-6);
	}

	.sidebar-widgets :global(.widget) {
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		color: var(--color-text-secondary);
	}

	.sidebar-widgets :global(.widget__title) {
		margin-bottom: var(--spacing-3);
	}

	.sidebar-widgets :global(.widget-search__input) {
		width: 100%;
		padding: 0.7rem var(--spacing-3);
		border: 1px solid var(--color-border);
		background: var(--color-surface);
		color: var(--color-text);
	}

	.sidebar-widgets :global(.widget-search__button) {
		display: none;
	}

	.sidebar-widgets :global(.widget-categories),
	.sidebar-widgets :global(.widget-recent-posts),
	.sidebar-widgets :global(.widget-archives) {
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.sidebar-widgets :global(.widget-categories li),
	.sidebar-widgets :global(.widget-recent-posts li),
	.sidebar-widgets :global(.widget-archives li) {
		padding: var(--spacing-2) 0;
		border-bottom: 1px solid var(--color-border-subtle);
	}

	.sidebar-widgets :global(.widget-categories li:last-child),
	.sidebar-widgets :global(.widget-recent-posts li:last-child),
	.sidebar-widgets :global(.widget-archives li:last-child) {
		border-bottom: none;
	}

	.sidebar-widgets :global(.widget-categories__link),
	.sidebar-widgets :global(.widget-recent-posts a),
	.sidebar-widgets :global(.widget-archives__link) {
		color: var(--color-text-secondary);
	}

	.sidebar-widgets :global(.widget-categories__count),
	.sidebar-widgets :global(.widget-archives__count) {
		font-size: var(--font-size-xs);
		color: var(--color-muted);
	}

	.sidebar-widgets :global(.widget-tags__cloud) {
		list-style: none;
		display: flex;
		flex-wrap: wrap;
		gap: var(--spacing-2);
		margin: 0;
		padding: 0;
	}

	.sidebar-widgets :global(.widget-tags__link) {
		display: inline-flex;
		padding: 0.35rem 0.6rem;
		border: 1px solid var(--color-border);
		font-size: var(--font-size-xs);
		text-transform: uppercase;
		letter-spacing: var(--tracking-wide);
		color: var(--color-text-secondary);
	}

	.sidebar-widgets :global(.widget-tags__count) {
		display: none;
	}

	.article-comments {
		margin-top: var(--spacing-12);
		padding-top: var(--spacing-8);
		border-top: 1px solid var(--color-border);
	}

	.article-comments :global(.ec-comments) {
		--ec-comment-border: 1px solid var(--color-border);
	}

